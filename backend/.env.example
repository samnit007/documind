ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key
# Supabase session pooler URL (Project Settings → Database → Session pooler)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_ID:your-password@aws-1-REGION.pooler.supabase.com:5432/postgres

# claude | openai | ollama
DEFAULT_LLM=claude

# Ollama (only needed if DEFAULT_LLM=ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b
FAST_MODEL=claude-haiku-4-5-20251001
SMART_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=text-embedding-3-small

CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_K=5
